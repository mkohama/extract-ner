# kb-mcp サーバの接続先 URL
# kb-mcp 側で `uv run kb-mcp-server --transport http --port 8000` を起動しておくこと。
# 設定しない場合の既定値は http://localhost:8000/mcp。
KB_MCP_URL=http://localhost:8000/mcp

# --- LLM 検出（pii-masker / Azure OpenAI gpt-4.1-mini）。LLM 経路を使うときのみ必要 ---
# pii-masker の client.py が load_dotenv で読むのは **data-redactor 側のこの .env**（呼び出し元 CWD）。
# よって pii-masker でなく data-redactor 側に設定する。Azure 実呼び出しは `az login` 済みの実機のみ。
# Azure リソース名（エンドポイント https://<ここ>.openai.azure.com）。実機で設定。
RESOURCE_NAME_GPT41_MINI=
# 既定モデル（Azure のデプロイ名。client.py が対応するのは gpt-4.1-mini のみ）。
DEFAULT_LLM_MODEL=gpt-4.1-mini

# --- LLM 検出の窓ポリシー（任意・チューニング用）---
# 本文を LLM に渡す前の「窓」分割の大きさ。未設定なら既定（max=7000 / overlap=0, src/llm/windows.py）。
# ここを変えると detector_version に自動反映され、**LLM 検出キャッシュが自動で無効化＝再検出**される
# （コード編集・コミット不要。値を戻せば元のキャッシュに再びヒットする）。
# 1 窓の上限トークン数（小さくすると窓が増え API 回数↑だが mini の長文取りこぼしは減る）。
LLM_WINDOW_MAX_TOKENS=7000

# 窓間の重なりトークン数（0=重なり無し。継ぎ目の先行文脈を持ち越したいなら 100〜200）。
LLM_WINDOW_OVERLAP_TOKENS=0
