# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# ツールのキャッシュ
.mypy_cache/
.ruff_cache/
.pytest_cache/

# 環境変数 (.env.example はコミットする)
.env

# 生成物・実行時ログ
ner.html
*.log

# デバッグ出力（実データを含みうるのでコミットしない）
debug_tokens*.txt

# 開発メモ（管理対象外）
docs-dev/

# テスト用データ（ローカルのみ）
testdata/

# マスク辞書（実データ＝社名・商標・社員名）はコミットしない（.env 同様）。
# 書式は data/mask_dict.sample.yaml（コミット対象）を参照。
data/*.yaml
!data/*.sample.yaml

# Office の一時ロックファイル
~$*
